# ─── Server ───
NODE_ENV=development
PORT=3000

# ─── MongoDB ───
MONGO_URI=mongodb://localhost:27017/hardened-auth

# ─── Redis ───
REDIS_URI=redis://localhost:6379

# ─── JWT Secrets (generate strong random values) ───
JWT_SECRET=your-access-token-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-64-chars
JWT_ISSUER=hardened-auth-api
JWT_AUDIENCE=hardened-auth-client

# ─── Access / Refresh Token TTL ───
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Cookies ───
COOKIE_SECRET=your-cookie-secret-min-32-chars

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/oauth/google/callback

# ─── 2FA ───
TWO_FACTOR_APP_NAME=HardenedAuth

# ─── Account Lockout ───
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15
